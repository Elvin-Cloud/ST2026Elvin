        "import json\n",
        "# Exercise 1\n",
        "# 1. Classification Step we take\n",
        "def classify_intent(user_message):\n",
        "    # In a real app, this would be an API call to an LLM\n",
        "    # For this assignment, we simulate the 'Refund' intent based on the message\n",
        "    if \"money back\" in user_message.lower() or \"refund\" in user_message.lower():\n",
        "        return \"refund\"\n",
        "    return \"tech\"\n",
        "\n",
        "# 2. Response Step (The Chain)\n",
        "def generate_response(intent, user_message):\n",
        "    # This simulates what the LLM would return based on the Intent from Step 1\n",
        "    response_data = {\n",
        "        \"intent\": intent,\n",
        "        \"customer_message\": user_message,\n",
        "        \"reply\": \"I'm so sorry to hear your gadget arrived broken. I have initiated a refund request, and you will receive a confirmation email shortly.\"\n",
        "    }\n",
        "\n",
        "    # We turn the dictionary into aa JSON string..\n",
        "    response_json = json.dumps(response_data)\n",
        "    return response_json\n",
        "\n",
        "# Final piece\n",
        "user_input = \"My gadget arrived broken and I want my money back.\"\n",
        "intent = classify_intent(user_input)\n",
        "final_output = generate_response(intent, user_input)\n",
        "\n",
        "print(f\"Detected Intent: {intent}\")\n",
        "print(\"Final JSON Output:\")\n",
        "print(final_output)"
